# ==============================================================================
# ALLBRIGHT RENDER DEPLOYMENT CONFIGURATION
# Copy this file to .env.render and fill in your API keys
# DO NOT commit .env.render to git - add it to .gitignore
# ==============================================================================

# -----------------------------------------------------------------------------
# CORE BACKEND CONFIGURATION
# -----------------------------------------------------------------------------
RUST_LOG=info
PILOT_MODE=true
HTTP_BIND_ADDR=0.0.0.0:3001

# -----------------------------------------------------------------------------
# AI API KEYS (Required for Commander/Copilot functionality)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GROQ_API_KEY=gsk-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# -----------------------------------------------------------------------------
# BLOCKCHAIN / EXECUTION (Optional for live trading)
# Leave empty for simulation mode
# -----------------------------------------------------------------------------
PRIVATE_KEY=0xyour-private-key-here
WALLET_ADDRESS=0xyour-wallet-address-here
EXECUTOR_ADDRESS=0xyour-executor-address-here

# -----------------------------------------------------------------------------
# ACCOUNT ABSTRACTION (Optional)
# -----------------------------------------------------------------------------
PIMLICO_API_KEY=pim_your-key-here
PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/ethereum/rpc?apikey=pim_your-key-here

# -----------------------------------------------------------------------------
# FLASH LOAN CONTRACT
# -----------------------------------------------------------------------------
FLASHLOAN_CONTRACT_ADDRESS=0xyour-contract-address-here

# -----------------------------------------------------------------------------
# CHAIN CONFIGURATION
# -----------------------------------------------------------------------------
CHAIN_ID=1
ETH_RPC_URL=https://lb.drpc.live/ethereum/your-key
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your-key
BSC_RPC_URL=https://bsc-dataseed1.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key

# -----------------------------------------------------------------------------
# WEBSOCKET URLs (Optional - for real-time updates)
# -----------------------------------------------------------------------------
ETH_WS_URL=wss://lb.drpc.live/ethereum/your-key
BASE_WS_URL=wss://mainnet.base.org
POLYGON_WS_URL=wss://polygon-mainnet.infura.io/v3/your-key

# -----------------------------------------------------------------------------
# DASHBOARD AUTH (Optional - for production)
# -----------------------------------------------------------------------------
SESSION_SECRET=your-long-random-secret-here-min-32-chars

# -----------------------------------------------------------------------------
# DEPLOYMENT MODE
# -----------------------------------------------------------------------------
# Leave VITE_ENGINE_MODE=simulation for safe deployment
# Change to 'production' only when ready for live trading
VITE_ENGINE_MODE=simulation
VITE_DEMO_MODE=true
VITE_DEBUG=false