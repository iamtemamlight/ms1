# ALLBRIGHT Local Development Docker Compose
# Simplified for local port exposure

services:
  # ============================================================================
  # BACKEND (Rust gRPC Server) - M01-M60 Modules
  # ============================================================================
  backend:
    build:
      context: .
      dockerfile: backend/Dockerfile
    container_name: allbright-backend
    ports:
      - "50051:50051"
      - "50052:50052"
      - "3001:3000"
    environment:
      - RUST_LOG=info
      - PILOT_MODE=true
      - DATABASE_URL=postgresql://apxuser:apxpass@postgres:5432/allbright
      - REDIS_URL=redis://redis:6379
      - HTTP_BIND_ADDR=0.0.0.0:3000
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - apx-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "grpcurl", "-plaintext", "localhost:50051", "list"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp:size=64M,mode=1777

  # ============================================================================
  # POSTGRES DATABASE
  # ============================================================================
  postgres:
    image: postgres:15-alpine
    container_name: allbright-postgres
    environment:
      - POSTGRES_USER=apxuser
      - POSTGRES_PASSWORD=apxpass
      - POSTGRES_DB=allbright
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./wme_schema.sql:/docker-entrypoint-initdb.d/wme_schema.sql
    ports:
      - "5432:5432"
    networks:
      - apx-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U apxuser -d allbright"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ============================================================================
  # REDIS CACHE
  # ============================================================================
  redis:
    image: redis:7-alpine
    container_name: allbright-redis
    command: redis-server --maxmemory 256mb --maxmemory-policy allkeys-lru
    ports:
      - "6379:6379"
    networks:
      - apx-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ============================================================================
  # PROMETHEUS METRICS
  # ============================================================================
  prometheus:
    image: prom/prometheus:latest
    container_name: allbright-prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    ports:
      - "9090:9090"
    networks:
      - apx-network
    restart: unless-stopped

  # ============================================================================
  # DASHBOARD FRONTEND (React + Vite + Tauri)
  # ============================================================================
  dashboard:
    build:
      context: .
      dockerfile: apps/dashboard/Dockerfile
    container_name: allbright-web-dashboard
    ports:
      - "5173:80"  # Vite dev server
    environment:
      - VITE_API_URL=http://backend:50051
      - VITE_WS_URL=ws://backend:50052
    depends_on:
      - backend
    networks:
      - apx-network
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost/"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  # ============================================================================
  # LOCALPORT FLEET RPC (EVM Multi-Chain Endpoints)
  # ============================================================================
  localport-rpc:
    image: ethereum/client-go:latest
    container_name: allbright-localport-rpc
    command: --http --http.addr 0.0.0.0 --http.vhosts * --http.api eth,net,debug,txpool --ws --ws.addr 0.0.0.0 --ws.api eth,net,debug,txpool --datadir /data
    ports:
      - "8545:8545"   # Primary Fleet RPC (HTTP)
      - "8546:8546"   # Secondary RPC (Backup)
      - "8547:8547"   # Shadow-Fork Simulation RPC
      - "8548:8548"   # Testing/QA RPC
      - "8549:8549"   # Arbitrum One RPC Mirror
    volumes:
      - localport-data:/data
    networks:
      - apx-network
    restart: unless-stopped

networks:
  apx-network:
    driver: bridge

volumes:
  postgres-data:
  prometheus-data:
  localport-data:
