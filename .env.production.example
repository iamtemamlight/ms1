# ==============================================================================
# ALLBRIGHT PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and fill in your ACTUAL production values
# WARNING: Never commit .env.production to version control
# ==============================================================================

# ==============================================================================
# AI/ML API CONFIGURATION
# ==============================================================================

# OpenAI API (for AI agents and copilot)
OPENAI_API_KEY=sk-your-production-openai-key-here

# Google AI Studio / Gemini
GOOGLE_AI_STUDIO=AIzaSy-your-production-google-ai-key-here
GEMINI_API_KEY=AIzaSy-your-production-gemini-key-here

# Groq API (fast inference)
ALLBRIGHT_GROQ=gsk_your-production-groq-key-here

# OpenRouter (multi-model access)
OPENROUTER_API_KEY=sk-or-v1-your-production-openrouter-key-here

# ==============================================================================
# BLOCKCHAIN CONFIGURATION
# ==============================================================================

# Wallet Configuration (USE HARDWARE WALLET IN PRODUCTION)
WALLET_ADDRESS=0xYourProductionWalletAddressHere
PRIVATE_KEY=VAULT_MANAGED  # Use hardware wallet or secrets manager
PROFIT_WALLET_ADDRESS=0xYourProductionProfitWalletAddressHere
EXECUTOR_ADDRESS=0xYourProductionExecutorAddressHere
FLASHLOAN_CONTRACT_ADDRESS=0xYourProductionFlashLoanContractAddressHere

# Chain Configuration (Mainnet)
CHAIN_ID=1  # Ethereum Mainnet
PAPER_TRADING_MODE=false  # FALSE for production
MEV_PROTECTION=true

# Scanning Configuration
SCAN_CONCURRENCY=8
MAX_PAIRS_TO_SCAN=1000
FLASH_LOAN_MAX=100000000  # Production value

# ==============================================================================
# RPC ENDPOINTS (Mainnet)
# ==============================================================================

# Primary RPC (Mainnet)
RPC_ENDPOINT=https://eth.llamarpc.com
ETH_RPC_URL=https://lb.drpc.live/ethereum/your-key
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your-project-id
BSC_RPC_URL=https://bsc-dataseed1.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Premium RPC Providers
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_WCC_UPC=wss://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
ANKR_RPC_URL=https://rpc.ankr.com/eth/your-ankr-key

# WebSocket URLs for Multi-Chain Sync
ETH_WS_URL=wss://lb.drpc.live/ethereum/your-key
BASE_WS_URL=wss://mainnet.base.org
POLYGON_WS_URL=wss://polygon-mainnet.infura.io/v3/your-project-id
BSC_WS_URL=wss://bsc-dataseed1.binance.org
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/rpc
OPTIMISM_WS_URL=wss://mainnet.optimism.io
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/rpc
FANTOM_WS_URL=wss://fantom-rpc.publicnode.com

# ==============================================================================
# ACCOUNT ABSTRACTION / BUNDLER
# ==============================================================================

# Pimlico (Account Abstraction)
PIMLICO_API_KEY=pim_your-production-pimlico-key-here
PIMLICO_NETWORK=ethereum
PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/ethereum/rpc?apikey=pim_your-key
ENTRYPOINT_ADDR=0x0000000071727de22e5e9d8baf0edac6f37da032

# ==============================================================================
# SESSION / AUTH
# ==============================================================================

# Generate with: openssl rand -hex 64
SESSION_SECRET=your-production-session-secret-here-at-least-64-chars

# Dashboard credentials (USE STRONG PASSWORDS)
DASHBOARD_USER=admin
DASHBOARD_PASS=your-very-strong-production-password-here

# ==============================================================================
# DATABASE
# ==============================================================================

# PostgreSQL (Production database with SSL)
DATABASE_URL=postgresql://apxuser:strong-password@prod-db.allbright.io:5432/allbright?sslmode=require

# Redis (Production cache with authentication)
REDIS_URL=redis://:strong-password@prod-redis.allbright.io:6379

# ==============================================================================
# BACKEND API ENDPOINTS
# ==============================================================================

# Backend gRPC endpoint
VITE_BACKEND_API_URL=https://api.allbright.io:50051

# WebSocket endpoint for real-time updates
VITE_WS_URL=wss://api.allbright.io:3001

# ==============================================================================
# ENGINE CONTROL CONFIGURATION
# ==============================================================================

# Engine mode: simulation | shadow-fork | production
VITE_ENGINE_MODE=production

# Fleet RPC endpoint (mainnet)
VITE_FLEET_RPC_URL=https://mainnet-rpc.allbright.io:8545

# Private RPC for MEV protection
VITE_PRIVATE_RPC_URL=https://private-rpc.allbright.io

# ==============================================================================
# FLASHBOTS / MEV PROTECTION
# ==============================================================================

FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_KEY=your-production-flashbots-auth-key

# ==============================================================================
# OPTIONAL INTEGRATIONS
# ==============================================================================

# Biconomy (Account Abstraction)
BICONOMY_API_KEY=mee_your-production-biconomy-key
BICONOMY_PROJECT_ID=your-production-project-id

# Render API (if using Render for deployment)
RENDER_API_KEY=rnd_your-production-render-api-key

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# Environment
NODE_ENV=production
PORT=3000

# Debug settings (DISABLED IN PRODUCTION)
VITE_DEBUG=false
VITE_DEMO_MODE=false  # FALSE for production
VITE_LOG_LEVEL=info

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# 1. NEVER commit .env.production to version control
# 2. Use hardware wallets (YubiKey, Ledger, Trezor) for private keys
# 3. Use different credentials from dev/staging
# 4. Rotate API keys regularly (every 30 days)
# 5. Enable SSL/TLS for all database connections
# 6. Use strong passwords (min 32 chars, mixed case, numbers, symbols)
# 7. Monitor wallet activity with alerts
# 8. Enable 2FA on all exchange accounts
# 9. Use secrets manager (AWS Secrets Manager, HashiCorp Vault)
# 10. Enable IP whitelisting for database access
# ==============================================================================
