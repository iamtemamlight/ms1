# Allbright C2 Backend Environment Configuration
# Copy this file to .env and fill in your actual values.

# Network Bind Addresses
C2_BIND_ADDR=0.0.0.0:50051
HTTP_BIND_ADDR=0.0.0.0:3000

# Database
DATABASE_URL=postgres://localhost/allbright

# TLS Certificates (optional - falls back to plaintext if missing)
C2_CERT_DIR=./certs

# AI Provider API Keys (server-side only - never expose to frontend)
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
