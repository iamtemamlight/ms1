# ==============================================================================
# ALLBRIGHT DEPLOYMENT ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control
# ==============================================================================

# ==============================================================================
# AI/ML API CONFIGURATION
# ==============================================================================

# OpenAI API (for AI agents and copilot)
OPENAI_API_KEY=sk-your-openai-key-here

# Google AI Studio / Gemini
GOOGLE_AI_STUDIO=AIzaSy-your-google-ai-key-here
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# Groq API (fast inference)
ALLBRIGHT_GROQ=gsk_your-groq-key-here

# OpenRouter (multi-model access)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ==============================================================================
# BLOCKCHAIN CONFIGURATION
# ==============================================================================

# Wallet Configuration
WALLET_ADDRESS=0xYourWalletAddressHere
PRIVATE_KEY=0xYourPrivateKeyHere
PROFIT_WALLET_ADDRESS=0xYourProfitWalletAddressHere
EXECUTOR_ADDRESS=0xYourExecutorAddressHere
FLASHLOAN_CONTRACT_ADDRESS=0xYourFlashLoanContractAddressHere

# Chain Configuration
CHAIN_ID=1  # 1=Ethereum, 8453=Base, 137=Polygon
PAPER_TRADING_MODE=false  # Set to true for testing without real funds
MEV_PROTECTION=true

# Scanning Configuration
SCAN_CONCURRENCY=8
MAX_PAIRS_TO_SCAN=1000
FLASH_LOAN_MAX=100000000  # Max flash loan amount in wei

# ==============================================================================
# RPC ENDPOINTS
# ==============================================================================

# Primary RPC
RPC_ENDPOINT=https://eth.llamarpc.com
ETH_RPC_URL=https://lb.drpc.live/ethereum/your-key
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your-project-id
BSC_RPC_URL=https://bsc-dataseed1.binance.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-key

# Premium RPC Providers
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
ALCHEMY_WCC_UPC=wss://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
ANKR_RPC_URL=https://rpc.ankr.com/eth/your-ankr-key

# WebSocket URLs for Multi-Chain Sync
ETH_WS_URL=wss://lb.drpc.live/ethereum/your-key
BASE_WS_URL=wss://mainnet.base.org
POLYGON_WS_URL=wss://polygon-mainnet.infura.io/v3/your-project-id
BSC_WS_URL=wss://bsc-dataseed1.binance.org
ARBITRUM_WS_URL=wss://arb1.arbitrum.io/rpc
OPTIMISM_WS_URL=wss://mainnet.optimism.io
AVALANCHE_WS_URL=wss://api.avax.network/ext/bc/C/rpc
FANTOM_WS_URL=wss://fantom-rpc.publicnode.com

# ==============================================================================
# ACCOUNT ABSTRACTION / BUNDLER
# ==============================================================================

# Pimlico (Account Abstraction)
PIMLICO_API_KEY=pim_your-pimlico-key-here
PIMLICO_NETWORK=ethereum
PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/ethereum/rpc?apikey=pim_your-key
ENTRYPOINT_ADDR=0x0000000071727de22e5e9d8baf0edac6f37da032

# ==============================================================================
# SESSION / AUTH
# ==============================================================================

# Generate with: openssl rand -hex 64
SESSION_SECRET=your-very-long-random-secret-here-at-least-64-chars

# Dashboard credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=your-secure-password-here

# ==============================================================================
# DATABASE
# ==============================================================================

# PostgreSQL (Render/Neon/AWS RDS)
# DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL=postgresql://apxuser:apxpass@localhost:5432/allbright

# Redis
REDIS_URL=redis://localhost:6379

# ==============================================================================
# BACKEND API ENDPOINTS
# ==============================================================================

# Backend gRPC endpoint
VITE_BACKEND_API_URL=http://localhost:50051

# WebSocket endpoint for real-time updates
VITE_WS_URL=ws://localhost:3001

# ==============================================================================
# ENGINE CONTROL CONFIGURATION
# ==============================================================================

# Engine mode: simulation | shadow-fork | production
VITE_ENGINE_MODE=simulation

# Fleet RPC endpoint
VITE_FLEET_RPC_URL=http://localhost:8545

# Private RPC for MEV protection (optional)
VITE_PRIVATE_RPC_URL=

# ==============================================================================
# FLASHBOTS / MEV PROTECTION
# ==============================================================================

FLASHBOTS_RELAY_URL=https://relay.flashbots.net
FLASHBOTS_AUTH_KEY=your-flashbots-auth-key

# ==============================================================================
# OPTIONAL INTEGRATIONS
# ==============================================================================

# Biconomy (Account Abstraction)
BICONOMY_API_KEY=mee_your-biconomy-key
BICONOMY_PROJECT_ID=your-project-id

# Render API (if using Render for deployment)
RENDER_API_KEY=rnd_your-render-api-key

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# Environment
NODE_ENV=production
PORT=3000

# Debug settings
VITE_DEBUG=false
VITE_DEMO_MODE=true  # Set to false for live trading
VITE_LOG_LEVEL=info

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# 1. NEVER commit .env files to git
# 2. Use different credentials for dev/staging/production
# 3. Rotate API keys regularly
# 4. Use hardware wallets for large amounts
# 5. Enable 2FA on all exchange accounts
# 6. Monitor wallet activity with alerts
# ==============================================================================

