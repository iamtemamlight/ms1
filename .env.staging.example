# ==============================================================================
# ALLBRIGHT STAGING ENVIRONMENT CONFIGURATION
# Copy this file to .env.staging and fill in your staging values
# ==============================================================================

# ==============================================================================
# AI/ML API CONFIGURATION
# ==============================================================================

# OpenAI API (for AI agents and copilot)
OPENAI_API_KEY=sk-your-staging-openai-key-here

# Google AI Studio / Gemini
GOOGLE_AI_STUDIO=AIzaSy-your-staging-google-ai-key-here
GEMINI_API_KEY=AIzaSy-your-staging-gemini-key-here

# Groq API (fast inference)
ALLBRIGHT_GROQ=gsk_your-staging-groq-key-here

# OpenRouter (multi-model access)
OPENROUTER_API_KEY=sk-or-v1-your-staging-openrouter-key-here

# ==============================================================================
# BLOCKCHAIN CONFIGURATION
# ==============================================================================

# Wallet Configuration (Use testnet wallets for staging)
WALLET_ADDRESS=0xYourStagingWalletAddressHere
PRIVATE_KEY=0xYourStagingPrivateKeyHere
PROFIT_WALLET_ADDRESS=0xYourStagingProfitWalletAddressHere
EXECUTOR_ADDRESS=0xYourStagingExecutorAddressHere
FLASHLOAN_CONTRACT_ADDRESS=0xYourStagingFlashLoanContractAddressHere

# Chain Configuration (Use testnet for staging)
CHAIN_ID=11155111  # Sepolia testnet
PAPER_TRADING_MODE=true  # Always true for staging
MEV_PROTECTION=true

# Scanning Configuration
SCAN_CONCURRENCY=4
MAX_PAIRS_TO_SCAN=100
FLASH_LOAN_MAX=10000000  # Lower for staging

# ==============================================================================
# RPC ENDPOINTS (Testnet)
# ==============================================================================

# Primary RPC (Sepolia testnet)
RPC_ENDPOINT=https://sepolia.infura.io/v3/your-project-id
ETH_RPC_URL=https://sepolia.infura.io/v3/your-project-id
BASE_RPC_URL=https://sepolia.base.org
POLYGON_RPC_URL=https://amoy.infura.io/v3/your-project-id
BSC_RPC_URL=https://bsc-testnet.infura.io/v3/your-project-id

# WebSocket URLs for Testnet
ETH_WS_URL=wss://sepolia.infura.io/v3/your-project-id
BASE_WS_URL=wss://sepolia.base.org
POLYGON_WS_URL=wss://amoy.infura.io/v3/your-project-id

# ==============================================================================
# ACCOUNT ABSTRACTION / BUNDLER
# ==============================================================================

# Pimlico (Account Abstraction)
PIMLICO_API_KEY=pim_your-staging-pimlico-key-here
PIMLICO_NETWORK=ethereum
PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/ethereum/rpc?apikey=pim_your-key
ENTRYPOINT_ADDR=0x0000000071727de22e5e9d8baf0edac6f37da032

# ==============================================================================
# SESSION / AUTH
# ==============================================================================

# Generate with: openssl rand -hex 64
SESSION_SECRET=your-staging-session-secret-here-at-least-64-chars

# Dashboard credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=your-staging-password-here

# ==============================================================================
# DATABASE
# ==============================================================================

# PostgreSQL (Staging database)
DATABASE_URL=postgresql://apxuser:apxpass@staging-db.allbright.io:5432/allbright_staging

# Redis (Staging cache)
REDIS_URL=redis://staging-redis.allbright.io:6379

# ==============================================================================
# BACKEND API ENDPOINTS
# ==============================================================================

# Backend gRPC endpoint
VITE_BACKEND_API_URL=http://staging-api.allbright.io:50051

# WebSocket endpoint for real-time updates
VITE_WS_URL=ws://staging-api.allbright.io:3001

# ==============================================================================
# ENGINE CONTROL CONFIGURATION
# ==============================================================================

# Engine mode: simulation | shadow-fork | production
VITE_ENGINE_MODE=simulation

# Fleet RPC endpoint (testnet)
VITE_FLEET_RPC_URL=http://staging-rpc.allbright.io:8545

# Private RPC for MEV protection (optional)
VITE_PRIVATE_RPC_URL=

# ==============================================================================
# FLASHBOTS / MEV PROTECTION
# ==============================================================================

FLASHBOTS_RELAY_URL=https://relay-sepolia.flashbots.net
FLASHBOTS_AUTH_KEY=your-staging-flashbots-auth-key

# ==============================================================================
# OPTIONAL INTEGRATIONS
# ==============================================================================

# Biconomy (Account Abstraction)
BICONOMY_API_KEY=mee_your-staging-biconomy-key
BICONOMY_PROJECT_ID=your-staging-project-id

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# Environment
NODE_ENV=staging
PORT=3000

# Debug settings
VITE_DEBUG=false
VITE_DEMO_MODE=true  # Always true for staging
VITE_LOG_LEVEL=debug

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# 1. Use testnet wallets and RPC endpoints
# 2. Keep PAPER_TRADING_MODE=true
# 3. Use separate API keys from production
# 4. Monitor staging costs and usage
# 5. Enable detailed logging for debugging
# ==============================================================================
